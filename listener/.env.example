# BirdNet Listener — Docker configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# Your host machine's LAN IP (the IP the ESP32 will send UDP audio to)
BIRDNET_HOST_IP=192.168.1.100

# ESP32 IP address (required for bridge mode, optional for host mode)
BIRDNET_ESP32_IP=192.168.1.50

# Opus playout buffer size in milliseconds (optional)
# Default is ~48000ms (800 × 60ms frames). Lower = less latency, more stutter risk.
# Try 3000–5000 for low-latency testing.
#BUFFER_MS=3000
