( 1 VBAT_SENSE )
( 2 SW_GND )
)
( /00000008 CAP_RADIAL2 C2 100nF
( 1 VSOL_SENSE )
( 2 SW_GND )
)
( /00000009 SIP1 P1 GPIO7
( 1 MONITOR_EN )
)
( /0000000A SIP1 P2 GPIO8
( 1 VBAT_SENSE )
)
